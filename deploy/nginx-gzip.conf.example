# Global gzip for static assets (JS/CSS/HTML). Install via scripts/install-nginx-site.sh
# or: sudo cp deploy/nginx-gzip.conf.example /etc/nginx/conf.d/addchess-gzip.conf && sudo nginx -t && sudo systemctl reload nginx

gzip on;
gzip_vary on;
gzip_proxied any;
gzip_comp_level 6;
gzip_min_length 256;
gzip_types
    text/plain
    text/css
    text/javascript
    application/javascript
    application/json
    application/xml
    image/svg+xml;
