# Supplemental gzip settings (safe when nginx.conf already has "gzip on;").
# Install: bash scripts/enable-nginx-gzip.sh
# Do NOT add a second "gzip on;" here — that causes duplicate directive errors.

gzip_vary on;
gzip_proxied any;
gzip_comp_level 6;
gzip_min_length 256;
gzip_types
    text/plain
    text/css
    text/javascript
    application/javascript
    application/json
    application/xml
    image/svg+xml;
