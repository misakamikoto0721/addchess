{
  "name": "addchess",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:core": "npm run build -w @addchess/core",
    "build": "npm run build -w @addchess/app",
    "build:server": "npm run build:core && npm run build -w @addchess/server",
    "dev": "npm run dev -w @addchess/app",
    "dev:server": "npm run dev -w @addchess/server",
    "start:server": "npm run start -w @addchess/server",
    "test": "npm run test -w @addchess/core"
  }
}
